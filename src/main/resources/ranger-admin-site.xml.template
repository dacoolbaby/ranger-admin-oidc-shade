  <!-- ============================================================= -->
  <!-- OIDC Common Settings                                           -->
  --=============================================================== -->

  <!-- Display name on the login.jsp "Login with ..." button -->
  <property>
    <name>ranger.oidc.provider-name</name>
    <value>Microsoft Entra ID</value>
  </property>

  <!-- Auto-create Ranger user on first OIDC login.
       true  = users are auto-created with ROLE_USER (ssoEnabled path)
       false = users must be pre-created in Ranger; non-existent users get 403 -->
  <property>
    <name>ranger.oidc.auto-create-user</name>
    <value>true</value>
  </property>

  <!-- Cookie name for the OIDC session token -->
  <property>
    <name>ranger.oidc.cookie-name</name>
    <value>ranger_oidc_token</value>
  </property>

  <!-- HTTP header for Bearer token (API auth) -->
  <property>
    <name>ranger.oidc.token-header</name>
    <value>Authorization</value>
  </property>

  <!-- Browser User-Agent prefixes for auto-redirect detection -->
  <property>
    <name>ranger.oidc.browser.useragent</name>
    <value>Mozilla,Opera,AppleWebKit</value>
  </property>

  <!-- RP-Initiated Logout (optional, Entra ID v2.0) -->
  <!--
  <property>
    <name>ranger.oidc.end-session-endpoint</name>
    <value>https://login.microsoftonline.com/<YOUR_TENANT_ID>/oauth2/v2.0/logout</value>
  </property>
  -->

</configuration>
