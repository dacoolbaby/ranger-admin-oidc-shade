  <!-- ============================================================= -->
  <!-- OIDC Authentication (ranger-admin-oidc-shade)                  -->
  --=============================================================== -->
  <!--
    These properties are consumed by the ranger-admin-oidc-shade module.
    Requires: ranger-admin-oidc-shade-2.8.0.jar in WEB-INF/lib/

    For MS Entra ID (Azure AD), see the example values below.
    For Keycloak or other OIDC providers, update the endpoints accordingly.
  -->

  <!-- Master switch: set to true to enable OIDC login -->
  <property>
    <name>ranger.oidc.enabled</name>
    <value>true</value>
  </property>

  <!-- = = = = = MS Entra ID (Azure AD) Example = = = = = -->

  <!-- Tenant-specific issuer. Replace {tenant-id} with your Entra tenant ID.
       e.g. https://login.microsoftonline.com/12345678-1234-1234-1234-123456789abc/v2.0 -->
  <property>
    <name>ranger.oidc.issuer-uri</name>
    <value>https://login.microsoftonline.com/<YOUR_TENANT_ID>/v2.0</value>
  </property>

  <!-- Client ID from Entra App Registration -->
  <property>
    <name>ranger.oidc.client-id</name>
    <value><YOUR_ENTRA_APP_CLIENT_ID></value>
  </property>

  <!-- Client Secret from Entra App Registration > Certificates & secrets -->
  <property>
    <name>ranger.oidc.client-secret</name>
    <value><YOUR_ENTRA_APP_CLIENT_SECRET></value>
  </property>

  <!-- JWKS endpoint for token signature verification -->
  <property>
    <name>ranger.oidc.jwks-uri</name>
    <value>https://login.microsoftonline.com/<YOUR_TENANT_ID>/discovery/v2.0/keys</value>
  </property>

  <!-- Authorization endpoint (Entra ID v2.0) -->
  <property>
    <name>ranger.oidc.auth-endpoint</name>
    <value>https://login.microsoftonline.com/<YOUR_TENANT_ID>/oauth2/v2.0/authorize</value>
  </property>

  <!-- Token endpoint (Entra ID v2.0) -->
  <property>
    <name>ranger.oidc.token-endpoint</name>
    <value>https://login.microsoftonline.com/<YOUR_TENANT_ID>/oauth2/v2.0/token</value>
  </property>

  <!-- Callback URL: must match the redirect URI configured in Entra App Registration.
       Must use HTTPS (Entra ID requirement). The Ranger Admin host and port. -->
  <property>
    <name>ranger.oidc.redirect-uri</name>
    <value>https://<RANGER_HOST>:6182/login/oidc/callback</value>
  </property>

  <!-- Scopes to request from Entra ID -->
  <property>
    <name>ranger.oidc.scope</name>
    <value>openid profile email</value>
  </property>

  <!-- JWT claim used as the Ranger login ID.
       Entra ID: "preferred_username" (user@domain.com) or "upn" -->
  <property>
    <name>ranger.oidc.username-claim</name>
    <value>preferred_username</value>
  </property>

  <!-- JWT claim for email -->
  <property>
    <name>ranger.oidc.email-claim</name>
    <value>email</value>
  </property>

  <!-- JWT claim for group membership.
       Entra ID: "groups" returns group Object IDs by default.
       To get group names, configure "sAMAccountName" in Entra token config.
       Or use "roles" if you've configured App Roles in Entra. -->
  <property>
    <name>ranger.oidc.groups-claim</name>
    <value>groups</value>
  </property>

  <!-- OIDC groups that should get ROLE_SYS_ADMIN in Ranger.
       For Entra ID: use group Object IDs or group names (depending on groups-claim setting).
       Comma-separated, no spaces.
       Example with Object IDs: 12345678-1234-1234-1234-123456789abc,87654321-4321-4321-4321-cba987654321 -->
  <property>
    <name>ranger.oidc.admin-groups</name>
    <value><YOUR_RANGER_ADMIN_GROUP_ID></value>
  </property>

