<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans-4.3.xsd">

    <!--
      Spring XML configuration for the OIDC shade module.

      The primary configuration is done via Java @Configuration class
      (RangerOidcSecurityConfig), which is auto-detected by component scanning.

      This XML provides an alternative that can be imported into
      security-applicationContext.xml:
        <import resource="classpath:META-INF/spring/ranger-oidc-security.xml"/>
    -->

    <!-- OIDC Configuration -->
    <bean id="oidcConfiguration" class="org.apache.ranger.security.oidc.OidcConfiguration"/>

    <!-- OIDC Token Validator -->
    <bean id="oidcTokenValidator" class="org.apache.ranger.security.oidc.OidcTokenValidator">
        <constructor-arg ref="oidcConfiguration"/>
    </bean>

    <!-- OIDC Authentication Provider -->
    <bean id="oidcAuthenticationProvider" class="org.apache.ranger.security.oidc.OidcAuthenticationProvider"/>

    <!-- OIDC Authentication Filter -->
    <bean id="oidcAuthenticationFilter" class="org.apache.ranger.security.oidc.OidcAuthenticationFilter">
        <constructor-arg ref="oidcConfiguration"/>
        <constructor-arg ref="oidcTokenValidator"/>
        <constructor-arg ref="oidcAuthenticationProvider"/>
    </bean>

</beans>
